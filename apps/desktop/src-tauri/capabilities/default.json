{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for OpenX desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "desktop-commands",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/openx-server",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-open",
    "shell:allow-stdin-write",
    "shell:allow-kill"
  ]
}
