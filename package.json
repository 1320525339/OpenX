{
  "name": "openx",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @openx/executor-core --filter @openx/executor-acp --filter @openx/executor-connect --filter @openx/executor-pi --filter @openx/mcp-openx --filter @openx/connect-client run build && pnpm --parallel --filter @openx/server --filter @openx/web dev",
    "dev:server": "pnpm --filter @openx/server dev",
    "dev:web": "pnpm --filter @openx/web dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "connect:demo": "pnpm --filter @openx/connect-client build && node packages/connect-client/dist/cli.js",
    "e2e:connect": "node scripts/e2e-connect-auto.mjs",
    "e2e:acp": "node scripts/e2e-acp-run.mjs --mock",
    "e2e:acp-dispatch": "node scripts/e2e-acp-dispatch.mjs",
    "e2e:self": "node scripts/e2e-self-bootstrap.mjs",
    "miloco:setup": "node scripts/setup-miloco-integration.mjs",
    "miloco:connect": "node scripts/setup-miloco-integration.mjs --connect-wsl",
    "miloco:live": "node scripts/e2e-miloco-live.mjs",
    "miloco:smoke": "node scripts/miloco-smoke-goals.mjs",
    "miloco:batch2-smoke": "node scripts/miloco-batch2-smoke.mjs",
    "miloco:batch3-smoke": "node scripts/miloco-batch3-smoke.mjs",
    "miloco:batch3-cron-smoke": "node scripts/miloco-batch3-cron-smoke.mjs",
    "miloco:habit-suggest-smoke": "node scripts/miloco-habit-suggest-smoke.mjs",
    "miloco:create-task-smoke": "node scripts/miloco-create-task-smoke.mjs",
    "miloco:identity-register-smoke": "node scripts/miloco-identity-register-smoke.mjs",
    "miloco:layer-b": "node scripts/miloco-layer-b-watch.mjs",
    "miloco:layer-b-preflight": "node scripts/miloco-layer-b-preflight.mjs",
    "miloco:interactive-smoke": "node scripts/miloco-interactive-smoke.mjs",
    "miloco:interactive-wsl-smoke": "node scripts/miloco-interactive-wsl-smoke.mjs",
    "miloco:presence": "node scripts/miloco-presence-once.mjs",
    "miloco:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/miloco-live-preflight.ps1",
    "miloco:install-skills": "node scripts/install-miloco-skills.mjs",
    "miloco:e2e": "node scripts/e2e-miloco-integration.mjs",
    "desktop:dev": "pnpm --filter @openx/desktop build:server && pnpm --filter @openx/desktop dev",
    "desktop:build": "pnpm --filter @openx/desktop build:server && pnpm --filter @openx/desktop build",
    "desktop:build:debug": "pnpm --filter @openx/desktop build:server && pnpm --filter @openx/desktop build:debug",
    "desktop:portable": "pnpm --filter @openx/desktop package:portable",
    "desktop:portable:debug": "pnpm --filter @openx/desktop package:portable:debug",
    "vendors:zvec": "node scripts/fetch-vendor-zvec.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
